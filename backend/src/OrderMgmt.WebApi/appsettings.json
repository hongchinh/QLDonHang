{
  "ConnectionStrings": {
    "Default": ""
  },
  "Jwt": {
    "Issuer": "OrderMgmt",
    "Audience": "OrderMgmtClient",
    "Secret": "",
    "ExpiresInMinutes": 60
  },
  "Cors": {
    "Origins": []
  },
  "AuthCookie": {
    "Name": "qldh.refresh",
    "Path": "/api/auth",
    "SameSite": "Lax",
    "Secure": null
  },
  "Database": {
    "AutoMigrateAndSeed": false
  },
  "Seed": {
    "AdminPassword": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Features": {
    "QuotationOwnerScope": true
  },
  "QuotationExport": {
    "TemplatePath": "templates/template_baogia.xlsx",
    "LibreOfficePath": "C:/Program Files/LibreOffice/program/soffice.exe",
    "ConversionTimeoutSeconds": 60,
    "UserTemplatesPath": "templates/users",
    "UploadMaxBytes": 5242880,
    "UnzippedMaxBytes": 52428800,
    "AllowedMimeTypes": [
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    ]
  }
}
