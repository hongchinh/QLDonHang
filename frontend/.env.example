# API base URL the SPA calls.
#
# Local dev: leave as "/api" — Vite proxies /api → http://localhost:5050.
# Railway / production: set to the full backend URL, e.g.
#   VITE_API_BASE_URL=https://qldh-backend.up.railway.app/api
#
# VITE_API_BASE (legacy) is still read as a fallback.
VITE_API_BASE_URL=/api
