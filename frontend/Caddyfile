{
    # Disable Caddy's automatic HTTPS — Railway terminates TLS at the edge.
    auto_https off
    admin off
}

:{$PORT:8080} {
    root * /srv
    encode gzip zstd

    # Long cache for hashed asset files emitted by Vite.
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    # No cache for the SPA entry — index.html must always be fresh so users
    # pick up new asset hashes.
    @html path /index.html /
    header @html Cache-Control "no-cache, no-store, must-revalidate"

    # SPA fallback: any path that does not match a real file serves index.html.
    try_files {path} /index.html
    file_server

    log {
        output stdout
        format console
    }
}
